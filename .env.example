# ===============================
# Unified Business Agent Configuration
# ===============================
# Team Sleepyhead - Nasiko Hackathon 2026

# ===============================
# LLM Provider - Groq Cloud (FREE)
# ===============================
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Primary Model for Main Agent (Best quality)
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile

# Secondary Model for Planning & Aggregation (Fast & efficient)
GROQ_MODEL_SECONDARY=llama-3.1-70b-versatile

# Temperature Settings
AGENT_TEMPERATURE=0.2
PLANNER_TEMPERATURE=0.0
AGGREGATOR_TEMPERATURE=0.3

# ===============================
# Database Configuration
# ===============================

# MongoDB (Production) - Optional
# If not provided, will use file-based fallback
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=BusinessAgentDB
USE_MONGODB=true

# File-based Database (Development/Fallback)
# Used automatically if MongoDB unavailable
FALLBACK_DB_PATH=/tmp/business_agent_db.json

# ===============================
# Google APIs (Optional)
# ===============================
# Optional: calendar scheduling and Gmail features
# If not provided, app falls back to mock calendar/email modes.
# Get credentials from: https://console.cloud.google.com

# Optional path to Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=./credentials/google_credentials.json

# Google Calendar Configuration
GOOGLE_CALENDAR_ID=primary

# Optional Gmail credentials path (defaults to Google credentials path behavior)
GMAIL_CREDENTIALS_PATH=./credentials/google_credentials.json

# Optional SMTP fallback (not required)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ===============================
# Document AI / OCR Configuration
# ===============================
# Choose ONE of the following OCR services

# Option 1: Google Document AI (Recommended for production)
USE_GOOGLE_DOCUMENT_AI=false
GOOGLE_DOCUMENT_AI_PROJECT_ID=your_project_id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your_processor_id

# Option 2: Tesseract OCR (Free, runs locally)
USE_TESSERACT=true
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng

# Option 3: OCR.space API (Free tier available)
USE_OCR_SPACE=false
OCR_SPACE_API_KEY=your_ocr_space_api_key
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image

# ===============================
# Support Ticket System (Optional)
# ===============================
# If you want to integrate with external ticket system

TICKET_SYSTEM_TYPE=internal  # internal | zendesk | freshdesk | custom
# Use a real provider endpoint only when TICKET_SYSTEM_TYPE is not internal
# Example Zendesk: https://your-subdomain.zendesk.com/api/v2
# Example Freshdesk: https://your-domain.freshdesk.com/api/v2
TICKET_SYSTEM_ENDPOINT=
TICKET_SYSTEM_API_KEY=your_ticket_system_api_key

# ===============================
# Agent Configuration
# ===============================

# Agent Behavior
MAX_ITERATIONS=10
MAX_EXECUTION_TIME=30
ENABLE_STREAMING=false

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json  # json | text
LOG_FILE=./logs/agent.log

# ===============================
# Feature Flags
# ===============================
# Enable/disable specific modules

ENABLE_CUSTOMER_SERVICE=true
ENABLE_DATA_ANALYTICS=true
ENABLE_FINANCE=true
ENABLE_SCHEDULING=true
ENABLE_DOCUMENT_PROCESSING=true

# ===============================
# Mock Services (Development)
# ===============================
# Use mock implementations when external services unavailable
# Automatically enabled if credentials not found

USE_MOCK_CALENDAR=false
USE_MOCK_GMAIL=false
USE_MOCK_OCR=false
USE_MOCK_DATABASE=false

# ===============================
# File Storage
# ===============================

# Uploaded files (datasets, invoices, receipts)
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=10

# Processed data and reports
DATA_DIR=./data/datasets
REPORTS_DIR=./data/reports
RECEIPTS_DIR=./data/receipts

# ===============================
# Security & Rate Limiting
# ===============================

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Session Management
SESSION_TIMEOUT_MINUTES=30
SESSION_CLEANUP_INTERVAL_MINUTES=60

# ===============================
# Performance Tuning
# ===============================

# Connection Pooling
DB_CONNECTION_POOL_SIZE=10
API_CONNECTION_TIMEOUT=30

# Caching
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300

# ===============================
# Development Settings
# ===============================

# Debug Mode
DEBUG=false
RELOAD_ON_CHANGE=false

# Test Mode
TEST_MODE=false
USE_TEST_DATABASE=false

# ===============================
# Production Settings
# ===============================

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=1

# CORS Settings
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Health Check
HEALTH_CHECK_ENDPOINT=/health

# ===============================
# Nasiko Platform Settings
# ===============================

# Agent Metadata
AGENT_NAME=Unified Business Agent
AGENT_VERSION=1.0.0
AGENT_ORGANIZATION=Team Sleepyhead

# A2A Protocol
A2A_PROTOCOL_VERSION=0.2.9
A2A_PREFERRED_TRANSPORT=JSONRPC
